# .env.example
# Copy this file to .env.local and fill in your values

# Google Sheets API Configuration
VITE_GOOGLE_API_KEY=your_api_key_here
VITE_SPREADSHEET_ID=your_spreadsheet_id_here

# Optional: OAuth Client ID (if using OAuth instead of API key)
# VITE_OAUTH_CLIENT_ID=your_oauth_client_id

# App Configuration
VITE_APP_NAME=Survey Ekosistem Literasi
VITE_APP_URL=https://your-domain.com

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_OFFLINE_MODE=false

# ===================================
# HOW TO GET THESE VALUES:
# ===================================

# 1. VITE_GOOGLE_API_KEY:
#    - Go to: https://console.cloud.google.com/
#    - Create a new project or select existing
#    - Enable Google Sheets API
#    - Go to "Credentials" → "Create Credentials" → "API Key"
#    - Copy the API key
#    - IMPORTANT: Restrict the key to:
#      * Application restrictions: HTTP referrers (your domain)
#      * API restrictions: Google Sheets API only

# 2. VITE_SPREADSHEET_ID:
#    - Open your Google Sheet
#    - Copy the ID from URL:
#      https://docs.google.com/spreadsheets/d/[THIS_IS_THE_ID]/edit
#    - IMPORTANT: Make sure sheet is shared with "Anyone with the link can view"
#      (or use Service Account for better security)

# 3. Sheet Structure Required:
#    - Sheet 1 name: "responses"
#    - Sheet 2 name: "calculated_scores"
#    - Sheet 3 name: "aggregated_stats"
#    - Sheet 4 name: "config"
#    See FULLSTACK_PLANNING_LITERASI.md for detailed schema

# ===================================
# DEPLOYMENT NOTES:
# ===================================

# When deploying to Vercel:
# 1. Don't commit .env.local to git
# 2. Add env variables in Vercel dashboard:
#    Project Settings → Environment Variables
# 3. Redeploy after adding env vars

# Security Best Practices:
# - Never expose API keys in client-side code
# - Use domain restrictions for API keys
# - Consider using Service Account for production
# - Rotate keys regularly
